contract/artifacts/
contract/cache/
contract/typechain-types/
contract/deployments/

# 7. Vite / Frontend
frontend/.vite/

# 8. OS & Logs
.DS_Store
Thumbs.db
*.log
npm-debug.log*

# 9. Editor
.vscode/
.idea/
*.swp